  evolution-go:
    image: evoapicloud/evolution-go:latest
    container_name: evolution-go
    restart: always #unless-stopped
    ports:
      - "4000:4000"
    environment:
      # Servidor
      SERVER_PORT: 4000
      CLIENT_NAME: "evolution"

      # Seguran�a (OBRIGAT�RIO)
      GLOBAL_API_KEY: "sua chave api"

      # Banco de Dados PostgreSQL (RECOMENDADO)
      POSTGRES_AUTH_DB: "postgresql://postgres:postgres@postgres:5432/evogo_auth?sslmode=disable"
      POSTGRES_USERS_DB: "postgresql://postgres:postgres@postgres:5432/evogo_users?sslmode=disable"
      DATABASE_SAVE_MESSAGES: "false"

      # Logs e Debug
      WADEBUG: "INFO"
      LOGTYPE: "console"
      LOG_DIRECTORY: "/app/logs"
      LOG_MAX_SIZE: "100"
      LOG_MAX_BACKUPS: "5"
      LOG_MAX_AGE: "30"
      LOG_COMPRESS: "true"

      # Conex�o
      CONNECT_ON_STARTUP: "false"
      WEBHOOKFILES: "true"

      # Sistema
      OS_NAME: "Linux"

      # Eventos (Opcionais)
      WEBHOOK_URL: ""
      AMQP_URL: ""
      AMQP_GLOBAL_ENABLED: "false"
      NATS_URL: ""
      NATS_GLOBAL_ENABLED: "false"

      # Armazenamento de M�dia (Opcional)
      MINIO_ENABLED: "false"

      # Eventos
      EVENT_IGNORE_GROUP: "false"
      EVENT_IGNORE_STATUS: "true"

      # QR Code
      QRCODE_MAX_COUNT: "5"

    volumes:
      - ./evolution_data:/app/dbdata
      - ./evolution_logs:/app/logs
    networks:
      - evolution_network
    depends_on:
      - postgres
